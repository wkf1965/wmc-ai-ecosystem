# WMC AI Central Backend — environment template
# Copy to .env and adjust (never commit .env)

NODE_ENV=development
PORT=5000
API_PREFIX=/api

# ── PostgreSQL ────────────────────────────────────────────────
# Stage 4: Replace with your real credentials.
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/wmc_ai
DATABASE_ENABLED=false
# Set DATABASE_ENABLED=true after creating the database and running schema.sql

# Redis — queues for notifications & AI (Phase 8+)
WMC_REDIS_URL=redis://localhost:6379

# Auth
AUTH_MODE=mock                                    # mock | jwt
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AI Summary Engine (Phase 4+)
WMC_AI_PROVIDER=stub
WMC_AI_API_KEY=
WMC_AI_MODEL_DEFAULT=gpt-4o-mini

# Mock notifications (no real Telegram/WhatsApp keys)
NOTIFICATION_MODE=mock
NOTIFICATION_MOCK_DELAY_MS=400
NOTIFICATION_MOCK_FAIL_RATE=0

# Nursing backend bridge (Telegram mock bot)
NURSING_API_URL=http://localhost:4000
NURSING_API_PREFIX=/api/v1
NURSING_API_TOKEN=demo-token

# Mock WhatsApp (no WATI / Meta API yet)
WHATSAPP_MOCK_DELAY_MS=350
WHATSAPP_MOCK_FAIL_RATE=0

# Telegram (Phase 8 — leave empty for mock mode)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# WhatsApp Cloud API (Phase 8)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
