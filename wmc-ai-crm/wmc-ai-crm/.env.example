PORT=3000

# Spreadsheet ID from the sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=

# Path to the service account JSON key file (relative to project folder is OK)
GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json

# Append range is hardcoded in sheetsAppend.js as Sheet1!A:H (eight columns).
