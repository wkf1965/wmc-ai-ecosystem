# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Auth (generate a long random string for production)
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_EXPIRES_IN=7d

# Fixed Bearer token for admin@wmc.local only (UI smoke tests). Middleware resolves real admin from store.
# Set WMC_DEMO_AUTH=0 to disable (JWT-only).
WMC_DEMO_AUTH=
WMC_DEMO_AUTH_TOKEN=demo-token

# Temporary persistence — same logical tabs as PostgreSQL schema (docs/schema/)
# file = JSON at DATA_DIR/wmc-ai-store.json  |  google = live Google Sheets
SHEETS_MODE=file
DATA_DIR=./data/store

# Google Sheets when SHEETS_MODE=google: create a spreadsheet, share with the service account (Editor)
GOOGLE_SHEETS_SPREADSHEET_ID=
# Path to service account JSON (optional if GOOGLE_APPLICATION_CREDENTIALS is set)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=

# AI providers — natural language nursing parse (POST /nursing/parse)
# LLM_PROVIDER=auto|deepseek|openai|rules
LLM_PROVIDER=auto
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# PostgreSQL (optional — falls back to JSON file store when unset)
# DATABASE_URL=postgresql://user:pass@localhost:5432/wmc_ai
