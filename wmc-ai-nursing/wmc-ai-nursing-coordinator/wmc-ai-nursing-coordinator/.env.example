# Telegram (simulation first — real bot optional)
TELEGRAM_BOT_TOKEN=
# Private chat or group id for “Send test reply” (numeric)
TELEGRAM_CHAT_ID=
# Full HTTPS URL Telegram will POST to — for production use Express (`npm run telegram`, port 3001), not Vite:
# TELEGRAM_WEBHOOK_URL=https://YOUR_SUBDOMAIN.ngrok-free.app/api/integrations/telegram/webhook
TELEGRAM_WEBHOOK_URL=
# simulation = parse + mock store only; live | production = also sendMessage reply to nurse chat
TELEGRAM_MODE=simulation

# ── Inventory Module ─────────────────────────────────────────────────────────
# URL of the Telegram webhook server hosting the /api/inventory/* endpoints.
# Default: http://localhost:3001 (Vite proxy handles this automatically in dev).
# In production point to your deployed Express server.
VITE_TELEGRAM_SERVER_URL=http://localhost:3001

# Optional: override the base URL for inventory API calls from the React frontend.
# Leave empty in dev — Vite proxy forwards /api/inventory/* to VITE_TELEGRAM_SERVER_URL.
# Set in production if the frontend and backend are on different domains.
VITE_INVENTORY_API_BASE=

# ── Google Sheets (Inventory + All other modules) ────────────────────────────
# If these are not set the inventory API returns built-in demo data automatically.
# Get these from your Google Cloud service account credentials.
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ── Required Google Sheet Tabs (create these in your spreadsheet) ────────────
# Inventory_Logs        — timestamp, nurse_name, telegram_username, patient_name, room, item_key, size, qty, remarks
# Stock_Balance         — item_key, item_name, opening_stock, used, balance, minimum_level
# Patient_Usage         — patient_name, month, pampers_total, wet_tissue_total, milk_total, gloves_total, total_qty
# Nurse_Usage           — nurse_name, month, total_items_taken, pampers, wet_tissue, milk
# Low_Stock_Alerts      — timestamp, item_key, item_name, balance, minimum_level, deficit, status
# Inventory_Billing     — month, patient_name, room, item_category, total_qty, unit_price, total_amount, billing_status, remarks
# Inventory_Audit_Trail — timestamp, action_type, nurse_name, telegram_username, patient_name, room, item, qty, before_stock, after_stock, source, remarks
# attendance_records    — date, staff_name, telegram_username, normal_punch_in, normal_punch_out, ot_in, ot_out, ot_hours, ot_rate, ot_amount, record_status, approval_status, approved_by, remarks
# side_turning          — timestamp, room_number, patient_name, turning_position, nurse_name, next_turning_due, status, source
# Patientsroom          — room_number, patient_name, status, bed_number

# ── Strict Telegram nursing ───────────────────────────────────────────────────
# Strict Telegram nursing: Sheet roster-only identity (no demo/heuristic brain fallback). Server: NURSING_MODE=production
# Browser/localState: also set VITE_NURSING_MODE=production if the UI should mirror the same rules.
NURSING_MODE=
VITE_NURSING_MODE=

# Exposed to Vite client (optional UI hints)
VITE_API_BASE_URL=http://localhost:4000
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=
VITE_TELEGRAM_MODE=simulation

# Google Sheets — Telegram nursing rows + patient roster reads (Apps Script webhook).
# simulation = no outbound POST/read (default); live | production = POST JSON to GOOGLE_SHEET_WEBHOOK_URL
GOOGLE_SHEET_MODE=simulation
VITE_GOOGLE_SHEET_MODE=simulation
# Spreadsheet ID (same workbook as webhook). Required for Telegram bot to load patients + nursing_notes via read_table.
GOOGLE_SHEET_ID=
# Expected tabs include: Patientsroom (room_number, patients_name, …), room_status, room_module_nursing_notes; plus legacy routing tabs (e.g. nursing_notes).
# Deploy as Web App (POST), paste URL here:
GOOGLE_SHEET_WEBHOOK_URL=
