# Telegram (simulation first — real bot optional)
TELEGRAM_BOT_TOKEN=
# Private chat or group id for “Send test reply” (numeric)
TELEGRAM_CHAT_ID=
# Full HTTPS URL Telegram will POST to — for production use Express (`npm run telegram`, port 3001), not Vite:
# TELEGRAM_WEBHOOK_URL=https://YOUR_SUBDOMAIN.ngrok-free.app/api/integrations/telegram/webhook
TELEGRAM_WEBHOOK_URL=
# simulation = parse + mock store only; live | production = also sendMessage reply to nurse chat
TELEGRAM_MODE=simulation

# Strict Telegram nursing: Sheet roster-only identity (no demo/heuristic brain fallback). Server: NURSING_MODE=production
# Browser/localState: also set VITE_NURSING_MODE=production if the UI should mirror the same rules.
NURSING_MODE=
VITE_NURSING_MODE=

# Exposed to Vite client (optional UI hints)
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=
VITE_TELEGRAM_MODE=simulation

# Google Sheets — Telegram nursing rows + patient roster reads (Apps Script webhook).
# simulation = no outbound POST/read (default); live | production = POST JSON to GOOGLE_SHEET_WEBHOOK_URL
GOOGLE_SHEET_MODE=simulation
VITE_GOOGLE_SHEET_MODE=simulation
# Spreadsheet ID (same workbook as webhook). Required for Telegram bot to load patients + nursing_notes via read_table.
GOOGLE_SHEET_ID=
# Expected tabs include: Patientsroom (room_number, patients_name, …), room_status, room_module_nursing_notes; plus legacy routing tabs (e.g. nursing_notes).
# Deploy as Web App (POST), paste URL here:
GOOGLE_SHEET_WEBHOOK_URL=
